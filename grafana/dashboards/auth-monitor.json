{
  "dashboard": {
    "id": null,
    "uid": "auth-monitor",
    "title": "Auth Service Telemetry",
    "timezone": "browser",
    "schemaVersion": 30,
    "panels": [
      {
        "id": 1, "title": "Total Login Attempts", "type": "stat", "gridPos": {"h": 8, "w": 6},
        "targets": [{"expr": "sum(auth_login_attempts_total)", "legendFormat": "Attempts"}]
      },
      {
        "id": 2, "title": "Login Success Rate", "type": "gauge", "gridPos": {"h": 8, "w": 6},
        "targets": [{"expr": "sum(auth_login_success_total) / sum(auth_login_attempts_total)", "legendFormat": "Rate"}],
        "fieldConfig": {"defaults": {"min": 0, "max": 1, "unit": "percentunit"}}
      },
      {
        "id": 3, "title": "Avg Backend Validation Duration", "type": "graph", "gridPos": {"h": 8, "w": 6},
        "targets": [{"expr": "rate(auth_login_duration_seconds_sum[1m]) / rate(auth_login_duration_seconds_count[1m])", "legendFormat": "Backend"}],
        "yaxes": [{"unit": "s", "logBase": 1}]
      },
      {
        "id": 4, "title": "Avg Frontend Call Duration", "type": "graph", "gridPos": {"h": 8, "w": 6},
        "targets": [{"expr": "rate(frontend_backend_call_duration_seconds_sum[1m]) / rate(frontend_backend_call_duration_seconds_count[1m])", "legendFormat": "Frontend"}],
        "yaxes": [{"unit": "s", "logBase": 1}]
      }
    ]
  },
  "overwrite": true
}